{
  "name": "cobolens",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:sidecar": "cargo build --release --manifest-path sidecar/cobolens-analyze/Cargo.toml",
    "tauri:before-build": "npm run build && npm run build:sidecar",
    "m6:verify": "node tools/m6-verify/run.mjs",
    "ollama:check": "node tools/local-model/ollama-smoke.mjs",
    "desktop:smoke": "node tools/desktop/tauri-attached-smoke.mjs",
    "m6:fixture-graph": "node tools/m6-bakeoff/export-fixture-graph.mjs",
    "m6:parser-readiness": "node tools/parser-upgrade/readiness.mjs",
    "m6:mapa-probe": "node tools/parser-upgrade/mapa-probe.mjs",
    "m6:mapa-bakeoff": "node tools/m6-bakeoff/run.mjs --candidate mapa=sidecar/cobolens-analyze-mapa/bin/cobolens-analyze-mapa",
    "m6:compare-candidates": "node tools/parser-upgrade/compare-candidates.mjs",
    "m6:packaging-readiness": "node tools/parser-upgrade/packaging-readiness.mjs",
    "validate:benchmark": "node tools/benchmark-validation/run.mjs",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.90",
    "@ai-sdk/openai": "^3.0.78",
    "@openrouter/ai-sdk-provider": "^2.10.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "ai": "^6.0.216",
    "graphology": "^0.26.0",
    "ollama-ai-provider-v2": "^3.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sigma": "^3.0.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
